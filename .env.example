MYSQL_DATABASE=workmate_ai
MYSQL_ROOT_PASSWORD=change_me
MYSQL_HOST_PORT=3306
REDIS_HOST_PORT=6379
BACKEND_HOST_PORT=8080
FRONTEND_HOST_PORT=80
TZ=Asia/Shanghai

DB_URL=jdbc:mysql://localhost:3306/workmate_ai?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
DB_USERNAME=root
DB_PASSWORD=change_me

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_TIMEOUT=2s

# Local backend LLM. Keep the real API key only in your local .env.
WORKMATE_LLM_PROVIDER=deepseek
WORKMATE_LLM_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=your_local_key

# Docker backend LLM. Docker deployment defaults to Mock unless these values are changed.
DOCKER_WORKMATE_LLM_PROVIDER=mock
DOCKER_WORKMATE_LLM_MODEL=mock-llm
DOCKER_DEEPSEEK_BASE_URL=https://api.deepseek.com
DOCKER_DEEPSEEK_API_KEY=
